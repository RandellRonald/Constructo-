# ─── Constructo Environment Variables ──────────────────────────────
# Copy this file to .env and fill in the values

# ─── Database ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=constructo_root_2024
MYSQL_DATABASE=constructo
MYSQL_USER=constructo_user
MYSQL_PASSWORD=constructo_pass_2024
DATABASE_URL=mysql+asyncmy://constructo_user:constructo_pass_2024@localhost:3306/constructo

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=constructo-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Razorpay ────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Cloudinary ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── MSG91 (OTP) ────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=CNSTRO

# ─── Google Maps ─────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── App Config ──────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
